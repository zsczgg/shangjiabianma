 <section className="card form-card" style={{marginTop:18}}><h2>库存规格 · {p.skus.length}</h2><div className="spec-list">{p.skus.map(s=><div className={`spec ${s.status==='INACTIVE'?'inactive-block':''}`} key={s.id}><div style={{gridColumn:'1/-1'}}><div className="detail-head"><div><b>{s.spec}</b><small>{s.status==='INACTIVE'?'该规格已冻结，编码永久保留':'有效库存规格'}</small></div><Status active={s.status==='ACTIVE'}/></div>{s.status==='INACTIVE'&&<div className="warning">该规格已停用，扫码仍可追溯，但禁止继续使用。</div>}<div className="code-grid" style={{marginTop:12}}><CodeCard label="公司内部编码" value={s.internalCode}/>{s.externalCodes.map(c=><CodeCard key={c.id} label={c.label||c.type} value={c.value}/>)}</div></div></div>)}</div></section>
 <section className="card form-card" style={{marginTop:18}}><h2>备注</h2><p>{p.note||'暂无备注'}</p></section><section className="card form-card" style={{marginTop:18}}><h2>修改历史</h2>{p.changes.length?<div className="history">{p.changes.map(c=><div className="history-row" key={c.id}><time>{c.createdAt.toLocaleString('zh-CN')}</time><b>{c.field}</b><span>{c.oldValue||'（空）'} → {c.newValue||'（空）'}</span></div>)}</div>:<p className="sub">暂时没有修改记录</p>}</section></div>}
